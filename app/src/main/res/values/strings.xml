    <!-- intro -->
    <string name="intro_page1_title">Limits that actually work</string>
    <string name="intro_page1_body">Screen-time limits are easy to ignore. Pact gives each app a daily budget — and when it\'s up, the app actually locks. 📱➡️🗑️</string>
    <string name="intro_page2_title">Build your squad</string>
    <string name="intro_page2_body">Lock each other out of the doomscroll. Want more time? Ask your squad — they hold the key, not your willpower. 👯➡️🔒</string>
    <string name="intro_page3_title">No accounts. Pure privacy.</string>
    <string name="intro_page3_body">No email, no password, no servers. Everything is end-to-end encrypted — nobody in between can read a thing, not even us. 🚀</string>
    <string name="intro_welcome_title">Meet Pact</string>
    <string name="intro_welcome_body">A calmer relationship with your phone, held together by the people who care about you.</string>
    <string name="intro_welcome_cta">Get started</string>
    <string name="intro_get_started">Let\'s go</string>

    <!-- role select -->
    <string name="role_title">Who\'s setting up this phone?</string>
    <string name="role_body">Pact has two sides: the person locking their apps, and the trusted people who help hold them.</string>
    <string name="role_user_title">Block my apps</string>
    <string name="role_user_body">I want to lock distracting apps and let people I trust hold the key.</string>
    <string name="role_sponsor_title">I\'m the sponsor</string>
    <string name="role_sponsor_body">Someone I care about asked me to hold their unlock codes.</string>

    <!-- guardian step -->
    <string name="guardian_title">Choose your sponsor</string>
    <string name="guardian_body">Pick someone who wants to see you succeed — a partner, a parent, a close friend. They\'ll hold the unlock codes, so every unlock starts with asking them.</string>
    <string name="guardian_name_label">Their name</string>
    <string name="guardian_hint">Pick someone easy to reach — you\'ll need them every time you want back in.</string>

    <!-- pair step -->
