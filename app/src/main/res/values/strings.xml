    <!-- permission step -->
    <string name="perm_title">Turn on the shield</string>
    <string name="perm_body">One Android permission lets Pact notice when a locked app opens, so it can step in front. Here\'s exactly how to grant it:</string>
    <string name="perm_step1">Tap “Open settings” below</string>
    <string name="perm_step2">Find “Pact app shield” in the list — sometimes under “Installed apps” or “Downloaded apps”</string>
    <string name="perm_step3">Tap it and switch it on</string>
    <string name="perm_step4">Android will show a warning — that\'s normal. Pact only sees which app opens, never what\'s on your screen. Tap “Allow”</string>
    <string name="perm_step5">Come back here — this page turns green when it worked</string>
    <string name="perm_status_on">The shield is up. You\'re protected.</string>
    <string name="perm_status_waiting">Waiting for the shield…</string>
