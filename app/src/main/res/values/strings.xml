    <string name="pair_body">This QR code is the key to your locks. It\'s shown once — right now — and it belongs to %1$s, not you.</string>
    <string name="pair_qr_desc">Pairing QR code</string>
    <string name="pair_on_their_phone">On %1$s\'s phone:</string>
    <string name="pair_step1">Install Pact — the same app you\'re using now</string>
    <string name="pair_step2">During setup, pick “I\'m the sponsor”</string>
    <string name="pair_step3">Scan this QR code with the scan button there</string>
