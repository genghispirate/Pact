    <string name="app_name">Pact</string>
    <string name="accessibility_service_label">Pact app shield</string>
    <string name="accessibility_service_description">Pact uses this permission for exactly one thing: noticing when a locked app comes to the front so it can show the lock screen. It never reads what\'s on your screen, collects nothing, and works entirely offline.</string>

