    <string name="end_pact_title">إنهاء الميثاق؟</string>
    <string name="end_pact_body">اطلب من %1$s الرمز الحالي لإزالة كل الأقفال وإعادة الضبط.</string>
    <string name="repair_new_sponsor">كفيل جديد</string>
    <string name="repair_scan_title">امسح على هاتفه</string>
    <string name="repair_body_qr">على هاتف %1$s: ثبّت Pact واختر «أنا الكفيل»، أو امسح بواسطة Google Authenticator. المفتاح اليدوي:\n%2$s</string>
    <string name="repair_enter_code">أدخل الرمز الحالي من %1$s لإتمام الميثاق الجديد.</string>
