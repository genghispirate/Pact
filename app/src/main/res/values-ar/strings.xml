    <string name="reset_action">إنهاء الميثاق وإعادة الضبط…</string>
    <string name="reset_hint">يزيل كل الأقفال ويبدأ من جديد. يحتاج رمزًا من %1$s.</string>
    <string name="strict_off_title">إيقاف الوضع الصارم؟</string>
